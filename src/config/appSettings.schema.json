{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learning Kingdom App Settings Schema",
  "description": "Centralized game configuration for all Learning Kingdom games and UI settings",
  "type": "object",
  "required": ["app", "theme", "difficulty", "games", "audio", "ui", "leaderboard", "auth", "logging"],
  "properties": {
    "app": {
      "title": "Application Metadata",
      "type": "object",
      "required": ["name", "version", "environment"],
      "properties": {
        "name": { "type": "string", "default": "Learning Kingdom" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "environment": { "type": "string", "enum": ["development", "staging", "production"] }
      }
    },
    "theme": {
      "title": "Color Theme",
      "type": "object",
      "required": ["primary", "secondary", "success", "accent", "background", "borderRadius"],
      "properties": {
        "primary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "secondary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "success": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "accent": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "background": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "borderRadius": { "type": "string", "pattern": "^\\d+(px|rem|em)$" }
      }
    },
    "difficulty": {
      "title": "Difficulty Configuration",
      "type": "object",
      "required": ["levels", "default"],
      "properties": {
        "levels": {
          "type": "object",
          "properties": {
            "easy": { "type": "integer", "minimum": 1 },
            "medium": { "type": "integer", "minimum": 1 },
            "hard": { "type": "integer", "minimum": 1 }
          }
        },
        "default": { "type": "string", "enum": ["easy", "medium", "hard"] }
      }
    },
    "games": {
      "title": "Game-Specific Settings",
      "type": "object",
      "properties": {
        "multiplicationFlashcard": { "$ref": "#/definitions/gameConfig" },
        "speedChallenge": { "$ref": "#/definitions/gameConfig" },
        "matchGame": { "$ref": "#/definitions/gameConfig" },
        "flashcardChallenge": { "$ref": "#/definitions/gameConfig" },
        "kingdomSiege": { "$ref": "#/definitions/gameConfig" },
        "kingdomMaps": { "$ref": "#/definitions/gameConfig" },
        "trainingTable": { "$ref": "#/definitions/gameConfig" },
        "spelling": { "$ref": "#/definitions/gameConfig" },
        "numberCruncher": { "$ref": "#/definitions/gameConfig" }
      }
    },
    "audio": {
      "title": "Audio Configuration",
      "type": "object",
      "required": ["enabled", "defaultVolume", "sounds"],
      "properties": {
        "enabled": { "type": "boolean" },
        "defaultVolume": { "type": "number", "minimum": 0, "maximum": 1 },
        "sounds": {
          "type": "object",
          "properties": {
            "correct": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "frequency": { "type": "integer", "minimum": 20, "maximum": 20000 },
                "duration": { "type": "integer", "minimum": 0 }
              }
            },
            "incorrect": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "frequency": { "type": "integer", "minimum": 20, "maximum": 20000 },
                "duration": { "type": "integer", "minimum": 0 }
              }
            },
            "levelUp": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "duration": { "type": "integer", "minimum": 0 }
              }
            },
            "gameOver": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "duration": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "ui": {
      "title": "UI Customization",
      "type": "object",
      "required": ["animationsEnabled", "feedbackDuration", "transitionDuration"],
      "properties": {
        "animationsEnabled": { "type": "boolean" },
        "feedbackDuration": { "type": "integer", "minimum": 0, "description": "Milliseconds" },
        "transitionDuration": { "type": "integer", "minimum": 0, "description": "Milliseconds" }
      }
    },
    "leaderboard": {
      "title": "Leaderboard Configuration",
      "type": "object",
      "required": ["enabled", "maxEntries", "showGlobalStats", "guestScoresSaved"],
      "properties": {
        "enabled": { "type": "boolean" },
        "maxEntries": { "type": "integer", "minimum": 1 },
        "showGlobalStats": { "type": "boolean" },
        "guestScoresSaved": { "type": "boolean" }
      }
    },
    "auth": {
      "title": "Authentication Settings",
      "type": "object",
      "required": ["guestModeEnabled", "requireSignUpOnExit"],
      "properties": {
        "guestModeEnabled": { "type": "boolean" },
        "requireSignUpOnExit": { "type": "boolean" },
        "sessionTimeout": { "type": ["integer", "null"], "minimum": 0, "description": "Milliseconds, null = no timeout" }
      }
    },
    "logging": {
      "title": "Logging Configuration",
      "type": "object",
      "required": ["enabled", "level"],
      "properties": {
        "enabled": { "type": "boolean" },
        "level": { "type": "string", "enum": ["debug", "info", "warn", "error"] }
      }
    }
  },
  "definitions": {
    "gameConfig": {
      "title": "Base Game Configuration",
      "type": "object",
      "required": ["enabled", "platforms", "defaultDifficulty"],
      "properties": {
        "enabled": { "type": "boolean", "description": "Whether game is active" },
        "platforms": { "type": "string", "enum": ["desktop", "mobile", "both"], "description": "Target device(s)" },
        "defaultDifficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "timeLimits": {
          "type": "object",
          "description": "Time limits per game mode (null = untimed)",
          "additionalProperties": { "type": ["integer", "null"] }
        },
        "scoring": {
          "type": "object",
          "description": "Scoring rules",
          "additionalProperties": { "type": "number" }
        }
      }
    }
  }
}
