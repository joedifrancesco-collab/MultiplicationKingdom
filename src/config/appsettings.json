{
  "app": {
    "name": "Learning Kingdom",
    "version": "0.0.1",
    "environment": "development"
  },
  "theme": {
    "primary": "#6C63FF",
    "secondary": "#FF6B6B",
    "success": "#6BCB77",
    "accent": "#FFD93D",
    "background": "#F0F4FF",
    "borderRadius": "16px"
  },
  "difficulty": {
    "levels": {
      "easy": 1,
      "medium": 2,
      "hard": 3
    },
    "default": "medium"
  },
  "games": {
    "multiplicationFlashcard": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "timeLimits": {
        "timed": 60,
        "sprint": 30,
        "practice": null
      },
      "scoring": {
        "pointsPerCorrect": 10,
        "penaltyPerWrong": 5,
        "bonusTimeBonus": 1.2
      }
    },
    "speedChallenge": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "timeLimits": {
        "default": 45
      },
      "scoring": {
        "pointsPerCorrect": 10,
        "penaltyPerWrong": 5
      }
    },
    "matchGame": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "timeLimits": {
        "default": 120
      },
      "scoring": {
        "pointsPerMatch": 10,
        "penaltyPerMismatch": 2
      },
      "cardFlipDelay": 300
    },
    "flashcardChallenge": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "modes": {
        "practice": {
          "timed": false,
          "tracking": false
        },
        "timed": {
          "duration": 60,
          "timed": true,
          "tracking": true
        },
        "sprint": {
          "duration": 30,
          "timed": true,
          "tracking": true
        }
      }
    },
    "kingdomSiege": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "towerCount": 5,
      "timePerQuestion": 8,
      "scoring": {
        "pointsPerCorrect": 10,
        "penaltyPerWrong": 5
      }
    },
    "kingdomMaps": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "gridSize": 13,
      "timeLimits": {
        "timed": 180,
        "classic": null
      },
      "scoring": {
        "pointsPerCell": 5,
        "penaltyPerError": 2
      },
      "timedModePenalty": 10
    },
    "trainingTable": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "timeLimits": {
        "default": null
      }
    },
    "spelling": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "peekDuration": 1000,
      "scoring": {
        "pointsPerCorrect": 10,
        "penaltyPerWrong": 5
      }
    },
    "numberCruncher": {
      "enabled": true,
      "platforms": "both",
      "defaultDifficulty": "medium",
      "timeLimits": {
        "perNumber": 5
      },
      "difficulty": {
        "1": { "minDigits": 2, "maxDigits": 3 },
        "2": { "minDigits": 2, "maxDigits": 4 },
        "3": { "minDigits": 3, "maxDigits": 5 },
        "4": { "minDigits": 3, "maxDigits": 6 },
        "5": { "minDigits": 4, "maxDigits": 6 },
        "6": { "minDigits": 4, "maxDigits": 7 },
        "7": { "minDigits": 5, "maxDigits": 7 },
        "8": { "minDigits": 5, "maxDigits": 7 }
      },
      "scoring": {
        "basePoints": 100,
        "levelMultiplier": 1.5
      }
    }
  },
  "audio": {
    "enabled": true,
    "defaultVolume": 0.5,
    "sounds": {
      "correct": {
        "enabled": true,
        "frequency": 800,
        "duration": 200
      },
      "incorrect": {
        "enabled": true,
        "frequency": 300,
        "duration": 300
      },
      "levelUp": {
        "enabled": true,
        "duration": 400
      },
      "gameOver": {
        "enabled": true,
        "duration": 600
      }
    }
  },
  "ui": {
    "animationsEnabled": true,
    "feedbackDuration": 1000,
    "transitionDuration": 300
  },
  "leaderboard": {
    "enabled": true,
    "maxEntries": 100,
    "showGlobalStats": false,
    "guestScoresSaved": true
  },
  "auth": {
    "guestModeEnabled": true,
    "requireSignUpOnExit": true,
    "sessionTimeout": null
  },
  "logging": {
    "enabled": false,
    "level": "info"
  }
}
