rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Users Collection ──────────────────────────────────────────────────
    // Allow anyone to read (for username availability checks during signup)
    // Allow authenticated users to create a new user document
    // Allow users to update/delete their own profile
    match /users/{username} {
      allow create: if request.auth != null;
      allow read: if true;  // Allow anyone to read for signup username validation
      allow update, delete: if request.auth.uid == resource.data.uid;
    }

    // ── Leaderboard Collection ────────────────────────────────────────────
    // Allow authenticated users to write scores
    // Allow anyone to read (public leaderboard)
    match /leaderboard/{document=**} {
      allow create: if request.auth != null;
      allow read: if true;
      allow update, delete: if request.auth.uid == resource.data.uid;
    }

    // ── Spelling Attempts Collection ──────────────────────────────────────
    // Allow authenticated users to write their spelling attempts
    // Allow authenticated users to read (filtered by uid in client code)
    match /spelling_attempts/{document=**} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.uid;
    }

    // ── Number Cruncher Attempts Collection ───────────────────────────────
    // Allow authenticated users to write their number cruncher attempts
    // Allow anyone to read (for leaderboard)
    // Allow users to update/delete only their own attempts
    match /number_cruncher_attempts/{document=**} {
      allow create: if request.auth != null;
      allow read: if true;  // Allow anyone to read for public leaderboard
      allow update, delete: if request.auth.uid == resource.data.uid;
    }

    // ── Spelling Word Groups Collection ───────────────────────────────────
    // Word groups for spelling practice (created by teachers)
    // Allow anyone to read (students browse available word lists)
    // Allow anyone to create/update/delete (teacher password protection in UI)
    // TODO: In production, restrict to authenticated teachers with specific role
    match /spelling_word_groups/{document=**} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ── Deny all other access ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
